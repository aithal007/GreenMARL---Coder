{
  "tasks": [
    {
      "id": "task_001",
      "name": "Two Sum",
      "difficulty": "easy",
      "description": "Given a list of integers `nums` and a target integer `target`, return the indices of the two numbers that add up to the target. Assume exactly one solution exists and you may not use the same element twice.",
      "function_signature": "def two_sum(nums: list[int], target: int) -> list[int]:",
      "examples": [
        {"input": "nums=[2,7,11,15], target=9", "output": "[0,1]"},
        {"input": "nums=[3,2,4], target=6", "output": "[1,2]"}
      ],
      "test_cases": [
        {"nums": [2, 7, 11, 15], "target": 9, "expected": [0, 1]},
        {"nums": [3, 2, 4], "target": 6, "expected": [1, 2]},
        {"nums": [3, 3], "target": 6, "expected": [0, 1]}
      ],
      "hidden_assertions": [
        {"nums": [1, 4, 6, 8], "target": 12, "expected": [1, 3]},
        {"nums": [0, 4, 3, 0], "target": 0, "expected": [0, 3]}
      ],
      "time_limit_ms": 1000
    },
    {
      "id": "task_002",
      "name": "Valid Parentheses",
      "difficulty": "easy",
      "description": "Given a string `s` containing only '(', ')', '{', '}', '[' and ']', determine if the input string is valid. A string is valid if every open bracket is closed by the same type of bracket in the correct order.",
      "function_signature": "def is_valid(s: str) -> bool:",
      "examples": [
        {"input": "s='()'", "output": "True"},
        {"input": "s='()[]{}'", "output": "True"},
        {"input": "s='(]'", "output": "False"}
      ],
      "test_cases": [
        {"s": "()", "expected": true},
        {"s": "()[]{}", "expected": true},
        {"s": "(]", "expected": false},
        {"s": "([)]", "expected": false},
        {"s": "{[]}", "expected": true}
      ],
      "hidden_assertions": [
        {"s": "", "expected": true},
        {"s": "[", "expected": false},
        {"s": "(((()))){{{{}}}}[[[[]]]]", "expected": true}
      ],
      "time_limit_ms": 500
    },
    {
      "id": "task_003",
      "name": "Fibonacci with Memoization",
      "difficulty": "medium",
      "description": "Implement a function `fib(n)` that returns the nth Fibonacci number using memoization. fib(0)=0, fib(1)=1, fib(n)=fib(n-1)+fib(n-2). The function must handle n up to 50 efficiently.",
      "function_signature": "def fib(n: int) -> int:",
      "examples": [
        {"input": "n=0", "output": "0"},
        {"input": "n=1", "output": "1"},
        {"input": "n=10", "output": "55"}
      ],
      "test_cases": [
        {"n": 0, "expected": 0},
        {"n": 1, "expected": 1},
        {"n": 10, "expected": 55},
        {"n": 20, "expected": 6765}
      ],
      "hidden_assertions": [
        {"n": 35, "expected": 9227465},
        {"n": 50, "expected": 12586269025}
      ],
      "time_limit_ms": 500
    },
    {
      "id": "task_004",
      "name": "Maximum Subarray",
      "difficulty": "medium",
      "description": "Given an integer array `nums`, find the subarray with the largest sum and return its sum. (Kadane's algorithm expected.)",
      "function_signature": "def max_subarray(nums: list[int]) -> int:",
      "examples": [
        {"input": "nums=[-2,1,-3,4,-1,2,1,-5,4]", "output": "6"},
        {"input": "nums=[1]", "output": "1"},
        {"input": "nums=[5,4,-1,7,8]", "output": "23"}
      ],
      "test_cases": [
        {"nums": [-2, 1, -3, 4, -1, 2, 1, -5, 4], "expected": 6},
        {"nums": [1], "expected": 1},
        {"nums": [5, 4, -1, 7, 8], "expected": 23}
      ],
      "hidden_assertions": [
        {"nums": [-1, -2, -3], "expected": -1},
        {"nums": [0, 0, 0], "expected": 0},
        {"nums": [100, -1, 100], "expected": 199}
      ],
      "time_limit_ms": 500
    },
    {
      "id": "task_005",
      "name": "Group Anagrams",
      "difficulty": "medium",
      "description": "Given a list of strings `strs`, group the anagrams together. You can return the answer in any order.",
      "function_signature": "def group_anagrams(strs: list[str]) -> list[list[str]]:",
      "examples": [
        {"input": "strs=['eat','tea','tan','ate','nat','bat']", "output": "[['eat','tea','ate'],['tan','nat'],['bat']]"},
        {"input": "strs=['']", "output": "[['']]"},
        {"input": "strs=['a']", "output": "[['a']]"}
      ],
      "test_cases": [
        {"strs": ["eat", "tea", "tan", "ate", "nat", "bat"], "expected_sizes": [3, 2, 1]},
        {"strs": [""], "expected_sizes": [1]},
        {"strs": ["a"], "expected_sizes": [1]}
      ],
      "hidden_assertions": [
        {"strs": ["abc", "bca", "cab", "xyz", "zyx"], "expected_sizes": [3, 2]}
      ],
      "time_limit_ms": 1000
    }
  ]
}
